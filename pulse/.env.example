NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/pulse

# Redis (for session cache / rate limiting)
REDIS_URL=redis://localhost:6379

# Providers
ANTHROPIC_API_KEY=sk-ant-api03-replace-me
OPENAI_API_KEY=sk-proj-replace-me

# Security
# 32-byte hex key for encrypting Tenant API keys and credentials at rest.
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Logging
LOG_LEVEL=debug

# Webhooks (Production only)
# WEBHOOK_BASE_URL=https://pulse.runstate.mu
# TELEGRAM_WEBHOOK_SECRET=your-secret-token-here
